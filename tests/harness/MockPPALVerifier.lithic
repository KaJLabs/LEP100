module Harness::MockPPALVerifier

type bytes
type bytes32
type u8
type u32
type u64

struct AccountRef { chain_id: u32, addr: bytes32 }

contract MockPPALVerifier {
  state { allow: map[bytes32]bool }

  fn key(commitment: bytes32, scope: string, epoch: u64, nullifier: bytes32) -> bytes32 {
    return sys.hash_sha256(sys.encode("PPAL_MOCK", commitment, scope, epoch, nullifier))
  }

  public fn set_allowed(commitment: bytes32, scope: string, epoch: u64, nullifier: bytes32, yes: bool) {
    self.allow.set(key(commitment, scope, epoch, nullifier), yes)
  }

  public fn verify(
    commitment: bytes32,
    association_type: u8,
    scope: string,
    epoch: u64,
    nullifier: bytes32,
    a: AccountRef,
    b: AccountRef,
    proof: bytes
  ) -> bool {
    return self.allow.get(key(commitment, scope, epoch, nullifier)).unwrap_or(false)
  }
}
